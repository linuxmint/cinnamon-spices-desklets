{
  "layout": {
    "type": "layout",
    "pages": ["general-page", "style-page"],
    "general-page": {
      "type": "page",
      "title": "General",
      "sections": ["general-section", "temperature-section"]
    },
    "style-page": {
      "type": "page",
      "title": "Style",
      "sections": ["font-section"]
    },
    "temperature-section": {
      "type": "section",
      "title": "Temperature",
      "keys": ["temp-file-path", "temperature-unit", "update-interval"]
    },
    "general-section": {
      "type": "section",
      "title": "General",
      "keys": ["label-text", "scale-size", "hide-decorations"]
    },
    "font-section": {
      "type": "section",
      "title": "Schrift",
      "keys": ["font-size-label", "font-size-temperature", "dynamic-color-enabled"]
    }
  },
  "scale-size": {
    "type": "scale",
    "default": 1.0,
    "step": 0.1,
    "min": 0.3,
    "max": 3.0,
    "description": "Desklet scale size"
  },
  "hide-decorations": {
    "type": "checkbox",
    "description": "Hide decorations",
    "default": false
  },
  "temp-file-path": {
    "type": "entry",
    "default": "/sys/class/thermal/thermal_zone2/temp",
    "description": "Path to file with temperature value (thermal zone)"
  },
  "label-text": {
    "type": "entry",
    "default": "CPU Temperature",
    "description": "Text for the label"
  },
  "temperature-unit": {
    "type": "combobox",
    "default": "C",
    "options": {
      "\u00b0C": "C",
      "\u00b0F": "F"
    },
    "description": "Temperature unit (Celsius or Fahrenheit)"
  },
  "update-interval": {
    "type": "scale",
    "default": 1,
    "min": 1,
    "max": 60,
    "step": 1,
    "description": "Update interval in seconds"
  },
  "font-size-label": {
    "type": "spinbutton",
    "default": 12,
    "min": 8,
    "max": 100,
    "step": 1,
    "description": "Font size for the label text"
  },
  "font-size-temperature": {
    "type": "spinbutton",
    "default": 35,
    "min": 12,
    "max": 100,
    "step": 1,
    "description": "Font size for the temperature display"
  },
  "dynamic-color-enabled": {
    "type": "switch",
    "default": true,
    "description": "Dynamic color based on temperature"
  }
}
