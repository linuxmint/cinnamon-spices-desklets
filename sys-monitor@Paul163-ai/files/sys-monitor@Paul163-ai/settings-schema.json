        "description": "Appearance"
    },
    "desklet-scale": {
        "type": "scale",
        "default": 1.0,
        "min": 0.5,
        "max": 2.0,
        "step": 0.05,
        "description": "Desklet Scale"
    },
    "bg-color": {
        "type": "colorchooser",
