{
  "info-header": {
    "type": "label",
    "description": "Dieses Desklet benötigt ein laufendes Crypto Trading Journal.\ngithub.com/Mouses007/Crypto-Trading-Journal"
  },
  "server-host": {
    "type": "entry",
    "default": "localhost",
    "description": "Server-Host",
    "tooltip": "IP oder Hostname, z.B. 192.168.178.100 oder localhost"
  },
  "server-port": {
    "type": "spinbutton",
    "default": 8080,
    "min": 1024,
    "max": 65535,
    "step": 1,
    "units": "",
    "description": "Server-Port",
    "tooltip": "Standard: 8080"
  },
  "refresh-interval": {
    "type": "spinbutton",
    "default": 30,
    "min": 5,
    "max": 300,
    "step": 5,
    "units": "Sekunden",
    "description": "Aktualisierungsintervall"
  },
  "show-leverage": {
    "type": "checkbox",
    "default": true,
    "description": "Hebel anzeigen"
  },
  "show-mark-price": {
    "type": "checkbox",
    "default": true,
    "description": "Mark-Preis anzeigen"
  },
  "show-realized-pnl": {
    "type": "checkbox",
    "default": true,
    "description": "Realisierten PnL anzeigen",
    "tooltip": "Zeigt den bereits realisierten PnL der offenen Position (z.B. Funding-Fees)"
  },
  "show-bots": {
    "type": "checkbox",
    "default": true,
    "description": "Pionex-Bots anzeigen",
    "tooltip": "Zeigt laufende Pionex-Bots in einer eigenen Sektion (PnL/Marge in der jeweiligen Münze, z.B. SOL bei Coin-M)"
  },
  "show-github-link": {
    "type": "checkbox",
    "default": true,
    "description": "GitHub-Link in Fußzeile anzeigen"
  },
  "font-size": {
    "type": "spinbutton",
    "default": 12,
    "min": 9,
    "max": 18,
    "step": 1,
    "units": "px",
    "description": "Schriftgröße (Positionen)"
  },
  "font-size-ui": {
    "type": "spinbutton",
    "default": 11,
    "min": 8,
    "max": 16,
    "step": 1,
    "units": "px",
    "description": "Schriftgröße (Titel, Fußzeile, Gesamt)"
  },
  "bg-opacity": {
    "type": "spinbutton",
    "default": 88,
    "min": 0,
    "max": 100,
    "step": 5,
    "units": "%",
    "description": "Hintergrund-Transparenz (0 = unsichtbar, 100 = voll)"
  },
  "min-width": {
    "type": "spinbutton",
    "default": 480,
    "min": 300,
    "max": 900,
    "step": 20,
    "units": "px",
    "description": "Breite"
  }
}
