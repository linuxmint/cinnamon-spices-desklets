{
  "tempWarnC": {
    "type": "spinbutton",
    "default": 75,
    "min": 50,
    "max": 100,
    "step": 1,
    "units": "°C",
    "description": "Temperature warning threshold (amber)"
  },
  "tempCritC": {
    "type": "spinbutton",
    "default": 83,
    "min": 60,
    "max": 100,
    "step": 1,
    "units": "°C",
    "description": "Temperature critical threshold (red)"
  },
  "historySeconds": {
    "type": "spinbutton",
    "default": 120,
    "min": 30,
    "max": 600,
    "step": 30,
    "units": "s",
    "description": "Sparkline history window (seconds). Sample count = value ÷ 2."
  },
  "showProcessCount": {
    "type": "checkbox",
    "default": true,
    "description": "Show the number of compute processes per GPU"
  },
  "clickAction": {
    "type": "combobox",
    "default": "nvidia-smi-watch",
    "description": "Action when desklet is clicked",
    "options": {
      "Do nothing": "none",
      "Open nvidia-smi watch in terminal": "nvidia-smi-watch",
      "Open nvidia-settings": "nvidia-settings"
    }
  }
}
