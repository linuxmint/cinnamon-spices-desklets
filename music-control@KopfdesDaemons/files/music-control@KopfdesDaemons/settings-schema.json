{
  "header0": {
    "type": "header",
    "description": "General"
  },
  "scale-size": {
    "type": "scale",
    "default": 1,
    "min": 0.5,
    "max": 3,
    "step": 0.1,
    "description": "Desklet scale size"
  },
  "hide-decorations": {
    "type": "checkbox",
    "description": "Hide decorations",
    "default": true
  },
  "header1": {
    "type": "header",
    "description": "Border"
  },
  "border-color": {
    "type": "colorchooser",
    "default": "#ffffff",
