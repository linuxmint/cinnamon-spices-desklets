  },
  "border-size": {
    "type": "scale",
    "default": 0.2,
    "min": 0,
    "max": 1,
    "step": 0.1,
    "units": "em",
    "description": "Border size"
  },
  "border-radius": {
    "type": "scale",
    "default": 10,
    "min": 0,
    "max": 10,
    "step": 0.5,
    "units": "em",
    "description": "Border radius"
  },
  "header2": {
    "type": "header",
    "description": "Cover"
  },
  "cover-opacity": {
    "type": "scale",
    "min": 0.0,
    "max": 1.0,
    "step": 0.05,
    "default": 1.0,
    "description": "Opacity of the cover art"
  }
