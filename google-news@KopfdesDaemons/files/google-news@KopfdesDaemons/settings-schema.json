{
  "layout": {
    "type": "layout",
    "pages": ["general-page", "style-page"],
    "general-page": {
      "type": "page",
      "title": "General",
      "sections": ["size-section", "api-section"]
    },
    "style-page": {
      "type": "page",
      "title": "Style",
      "sections": ["style-section"]
    },
    "style-section": {
      "type": "section",
      "title": "Style",
      "keys": ["hide-decorations"]
    },
    "api-section": {
      "type": "section",
      "title": "API Settings",
      "keys": ["ceid", "refresh-interval"]
    },
    "size-section": {
      "type": "section",
      "title": "Size",
      "keys": ["scale-size", "width", "height"]
    }
  },
  "scale-size": {
    "type": "scale",
    "default": 1,
    "min": 0.5,
    "max": 2,
    "step": 0.1,
    "description": "Scale size"
  },
  "width": {
    "type": "spinbutton",
    "default": 35,
    "min": 10,
    "max": 100,
    "step": 1,
    "units": "em",
    "description": "Width"
  },
  "height": {
    "type": "spinbutton",
    "default": 40,
    "min": 10,
    "max": 100,
    "step": 1,
    "units": "em",
    "description": "Height"
  },
  "ceid": {
    "type": "entry",
    "default": "",
    "description": "Country and language",
    "tooltip": "e.g. US:en, DE:de"
  },
  "refresh-interval": {
    "type": "spinbutton",
    "default": 10,
    "min": 1,
    "max": 60,
    "step": 1,
    "description": "Refresh interval in minutes"
  },
  "hide-decorations": {
    "type": "checkbox",
    "default": true,
    "description": "Hide decorations"
  }
}
