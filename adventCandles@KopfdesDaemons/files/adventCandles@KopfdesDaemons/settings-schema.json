{
  "header0": {
    "type": "header",
    "description": "General"
  },
  "desklet-scale": {
    "type": "scale",
    "default": 1,
    "min": 0.5,
    "max": 2,
    "step": 0.1,
    "description": "Scale factor for desklet size"
  },
  "animation-enabled": {
    "type": "checkbox",
    "description": "Animate the candle flames",
    "default": true
  },
  "animation-speed": {
    "type": "scale",
    "default": 300,
    "min": 100,
    "max": 1000,
    "step": 10,
    "description": "Speed of candle animation in milliseconds",
    "dependency": "animation-enabled"
  },
  "number-of-lit-candles": {
    "type": "combobox",
    "default": "automatic",
    "options": {
      "automatic": "automatic",
      "0": "0",
      "1": "1",
      "2": "2",
      "3": "3",
      "4": "4"
    },
    "description": "Number of lit candles"
  },
  "header1": {
    "type": "header",
    "description": "Colors"
  },
  "color-preset": {
    "type": "combobox",
    "default": "red",
    "options": {
      "traditional": "traditional",
      "red": "red"
    },
    "description": "Color preset"
  },
  "candle-1-color": {
    "type": "colorchooser",
    "default": "#c01c28",
    "description": "Color of the 1st candle"
  },
  "candle-2-color": {
    "type": "colorchooser",
    "default": "#c01c28",
    "description": "Color of the 2nd candle"
  },
  "candle-3-color": {
    "type": "colorchooser",
    "default": "#c01c28",
    "description": "Color of the 3rd candle"
  },
  "candle-4-color": {
    "type": "colorchooser",
    "default": "#c01c28",
    "description": "Color of the 4th candle"
  }
}
