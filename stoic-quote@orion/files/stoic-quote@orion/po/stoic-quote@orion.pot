#. desklet.js:33 quotes.js:13
msgid ""
"The impediment to action advances action. What stands in the way becomes the "
"way."
msgstr ""

#. desklet.js:34 quotes.js:14 quotes.js:17 quotes.js:20 quotes.js:23
#. quotes.js:26 quotes.js:29 quotes.js:32 quotes.js:35 quotes.js:38
#. quotes.js:41 quotes.js:44 quotes.js:47 quotes.js:50 quotes.js:53
