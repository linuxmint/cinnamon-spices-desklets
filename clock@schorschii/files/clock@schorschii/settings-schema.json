{
    "head0": {
        "type": "header",
        "description": "Settings for clock@schorschii"
    },

    "head1": {
        "type": "header",
        "description": "Visual"
    },
    "style" : {
        "type": "combobox",
        "default" : "light",
        "description" : "Clock style",
        "options" : {
            "Light" : "light",
            "Dark": "dark",
            "Light Transparent": "light_transparent",
            "Dark Transparent": "dark_transparent",
            "Semitransparent": "semi_transparent",
            "Clock Style 01 Light": "style_01_light",
            "Clock Style 01 Dark": "style_01_dark",
            "Clock Style 02 Light": "style_02_light",
            "Clock Style 02 Dark": "style_02_dark",
            "Clock Style 03 Light": "style_03_light",
            "Clock Style 03 Dark": "style_03_dark",
            "Clock Style 04 Light": "style_04_light",
            "Clock Style 04 Dark": "style_04_dark",
            "Clock Style 05 Light": "style_05_light",
            "Clock Style 05 Dark": "style_05_dark",
            "Clock Style 06 Light": "style_06_light",
            "Clock Style 06 Dark": "style_06_dark",
            "Clock Style 07 Light": "style_07_light",
            "Clock Style 07 Dark": "style_07_dark",
            "Clock Style 08 Light": "style_08_light",
            "Clock Style 08 Dark": "style_08_dark",
            "Clock Style 09 Light": "style_09_light",
            "Clock Style 09 Dark": "style_09_dark",
            "Custom": "custom-images"
        },
        "tooltip" : "Select the background graphic you would like to use."
    },
    "background-color": {
        "type": "colorchooser",
        "default": "rgba(255,255,255,0)",
        "description": "Clock Background color, can be set to transparent"
    },
    "show-seconds-hand": {
        "type": "checkbox",
        "description": "Show seconds hand",
        "tooltip": "Show or hide the seconds hand.",
        "default": false
    },
    "smooth-seconds-hand": {
        "type": "checkbox",
        "description": "Smooth second hand",
        "tooltip": "Use smooth animation for seconds hand instead of refreshing it only every second.",
        "default": true
    },
    "smooth-minutes-hand": {
        "type": "checkbox",
        "description": "Smooth minute hand",
        "tooltip": "Use smooth animation for minute hand instead of moving it only once per minute.",
        "default": true
    },
    "hide-decorations": {
        "type": "checkbox",
        "description": "Hide decorations",
        "default": false
    },
    "desklet-size": {
        "type": "spinbutton",
        "default": 150,
        "min": 10,
        "max": 500,
        "step": 2,
        "units": "pixels",
        "description": "Desklet size",
        "tooltip": "Increase or decrease the size of the clock."
    },

    "head2": {
        "type": "header",
        "description": "Custom desklet label (only visible if decorations are enabled)"
    },
    "use-custom-label": {
        "type": "checkbox",
        "default": false,
        "description": "Use a custom desklet label",
        "tooltip": "Checking this box allows you to set a custom label in the field below.",
        "value": false
    },
    "custom-label": {
        "type": "entry",
        "default": "Clock 1",
        "description": "Custom desklet label",
        "indent": true,
        "dependency": "use-custom-label",
        "tooltip": "Set your custom label here, e.g. for multiple timezones. This field is unavailable unless the checkbox above is enabled."
    },

    "head3": {
        "type": "header",
        "description": "Timezone"
    },
    "use-custom-tz": {
        "type": "checkbox",
        "default": false,
        "description": "Use a custom timezone",
        "tooltip": "Checking this box allows you to set a custom timezone in the field below.",
        "value": false
    },
    "custom-tz": {
        "type": "entry",
        "default": "",
        "description": "Custom time zone",
        "indent": true,
        "dependency": "use-custom-tz",
        "tooltip": "Enter your custom timezone here."
    },
    "timezone-name": {
        "type": "entry",
        "default": "",
        "description": "Name of time zone to display",
        "indent": true,
        "dependency": "use-custom-tz",
        "tooltip": "Enter your timezone name here."
    },
    "label-font-color": {
        "type": "colorchooser",
        "default": "rgba(0,0,0,1)",
        "description": "Text Label font color"
    },
    "label-background-color": {
        "type": "colorchooser",
        "default": "rgba(255,255,255,0)",
        "description": "Text Label Background color, can be set to transparent"
    },
    
     "show-timezone-name": {
        "type": "checkbox",
        "default": false,
        "dependency": "use-custom-tz",
        "description": "Shows the Time Zone name below the clock",
        "tooltip": "For multiple clock, shows each clock Time Zone name below the clock",
        "value": false
    },

    "head4": {
        "type": "header",
        "description": "Custom images (available if clock style is set to 'custom')"
    },
    "img-bg": {
        "default": "",
        "type": "filechooser",
        "description" : "Background",
        "tooltip": "Choose your own background image.",
        "allow-none" : true
    },
    "img-s": {
        "default": "",
        "type": "filechooser",
        "description" : "Seconds hand",
        "tooltip": "Choose your own image for the seconds hand. Should be as big as the background image.",
        "allow-none" : true
    },
    "img-m": {
        "default": "",
        "type": "filechooser",
        "description" : "Minute hand",
        "tooltip": "Choose your own image for the minute hand. Should be as big as the background image.",
        "allow-none" : true
    },
    "img-h": {
        "default": "",
        "type": "filechooser",
        "description" : "Hour hand",
        "tooltip": "Choose your own image for the hour hand. Should be as big as the background image.",
        "allow-none" : true
    }
}
