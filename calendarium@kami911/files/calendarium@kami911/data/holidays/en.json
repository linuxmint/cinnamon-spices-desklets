{
  "fixed": {
    "01-01": {"name": "New Year's Day",  "public": true},
    "12-25": {"name": "Christmas Day",   "public": true},
    "12-26": {"name": "Boxing Day",      "public": true}
  },
  "easter": [
    {"offset": -2, "name": "Good Friday",    "public": true},
    {"offset":  0, "name": "Easter Sunday",  "public": true},
    {"offset":  1, "name": "Easter Monday",  "public": true},
    {"offset": 50, "name": "Whit Monday",    "public": false}
  ],
  "periods": [
    {
      "name": "Shrovetide",
      "public": false,
      "start": {"type": "fixed",  "month": 1, "day": 6},
      "end":   {"type": "easter", "offset": -47}
    },
    {
      "name": "Lent",
      "public": false,
      "start": {"type": "easter", "offset": -46},
      "end":   {"type": "easter", "offset": -1}
    },
    {
      "name": "Advent",
      "public": false,
      "start": {"type": "advent", "offset": 0},
      "end":   {"type": "fixed",  "month": 12, "day": 24}
    }
  ]
}
