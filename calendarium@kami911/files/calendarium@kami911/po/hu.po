#. settings-schema.json->date-format-custom->description
msgid ""
"Custom date format (strftime) — only active when 'Custom' is selected above"
msgstr ""
"Egyéni dátumformátum (strftime) — csak akkor aktív, ha fent az 'Egyéni' van "
"kiválasztvaEgyéni dátumformátum (strftime) — csak akkor aktív, ha fent az "
"'Egyéni' van kiválasztva"

#. settings-schema.json->date-format-custom->tooltip
msgid ""
"strftime codes: %A=full weekday  %a=short weekday  %d=day  %B=full month  "
"%b=short month  %Y=4-digit year  %y=2-digit year  %m=month number  %j=day of "
"year  %H=hour(24h)  %I=hour(12h)  %M=minute  %p=AM/PM.  Example: %Y. %B %d., "
"%A"
msgstr ""
"strftime kódok: %A = hét napjának teljes neve %a = hét napjának rövid neve "
"%d = nap %B = hónap teljes neve %b = hónap rövid neve %Y = 4 számjegyű év %y "
"= 2 számjegyű év %m = hónap száma %j = az év napja %H = óra (24 órás "
"formátum) %I = óra (12 órás formátum) %M = perc %p = de./du. Példa: %Y. %B "
"%d., %A"

