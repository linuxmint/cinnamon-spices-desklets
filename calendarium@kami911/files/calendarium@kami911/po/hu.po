#. ── settings-schema.json — tooltips ─────────────────────────────────────
#: settings-schema.json
msgid ""
"Select a predefined date format, or choose Custom to enter your own strftime "
"string below."
msgstr ""
"Válassz egy előre beállított dátumformátumot, vagy válaszd az Egyénit, hogy "
"alább megadd a saját strftime-kódodat."

#: settings-schema.json
msgid "Controls the display size of moon phase and zodiac symbols."
msgstr ""
"A holdfázis és horoszkóp szimbólumok megjelenítési méretét szabályozza."

#: settings-schema.json
msgid "Scale all text in the desklet up or down."
msgstr "Az összes szöveg nagyítása vagy kicsinyítése a deskletben."

#: settings-schema.json
msgid ""
"How long to keep Wikipedia data in the local cache before fetching fresh "
"data. Lower values fetch more often; higher values reduce network usage."
msgstr ""
"Mennyi ideig tárolja a Wikipédia adatokat a helyi gyorsítótárban, mielőtt "
"újat tölt le. Alacsonyabb értéknél sűrűbben frissít; magasabb értéknél "
"csökkenti a hálózathasználatot."

#: settings-schema.json
msgid "Choose what to show for the western zodiac sign."
msgstr "Válaszd ki, mit jelenítsen meg a nyugati állatövi jelnél."

#: settings-schema.json
msgid "Choose what to show for the Chinese zodiac year (animal and element)."
msgstr "Válaszd ki, mit jelenítsen meg a kínai állatövi évnél (állat és elem)."

#: settings-schema.json
msgid "Label for an additional city. Leave empty to hide."
msgstr "Egy további város felirata. Üresen hagyva elrejtve."

