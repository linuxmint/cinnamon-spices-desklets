#. ── settings-schema.json — tooltips ─────────────────────────────────────
#: settings-schema.json
msgid ""
"Select a predefined date format, or choose Custom to enter your own strftime "
"string below."
msgstr ""
"Sélectionnez un format de date prédéfini, ou choisissez Personnalisé pour "
"saisir votre propre code strftime ci-dessous."

#: settings-schema.json
msgid "Controls the display size of moon phase and zodiac symbols."
msgstr ""
"Contrôle la taille d'affichage des symboles de phase lunaire et de zodiaque."

#: settings-schema.json
msgid "Scale all text in the desklet up or down."
msgstr "Agrandir ou réduire tout le texte du desklet."

#: settings-schema.json
msgid ""
"How long to keep Wikipedia data in the local cache before fetching fresh "
"data. Lower values fetch more often; higher values reduce network usage."
msgstr ""
"Combien de temps conserver les données Wikipédia dans le cache local avant "
"d'en obtenir de nouvelles. Des valeurs faibles actualisent plus souvent ; "
"des valeurs élevées réduisent l'utilisation du réseau."

#: settings-schema.json
msgid "Choose what to show for the western zodiac sign."
msgstr ""
"Choisissez ce qu'il faut afficher pour le signe du zodiaque occidental."

#: settings-schema.json
msgid "Choose what to show for the Chinese zodiac year (animal and element)."
msgstr ""
"Choisissez ce qu'il faut afficher pour l'année du zodiaque chinois (animal "
"et élément)."

#: settings-schema.json
msgid "Label for an additional city. Leave empty to hide."
msgstr "Étiquette pour une ville supplémentaire. Laisser vide pour masquer."

