#. settings-schema.json->date-format-custom->description
msgid ""
"Custom date format (strftime) — only active when 'Custom' is selected above"
msgstr ""
"Format de date personnalisé (strftime) — actif uniquement quand "
"'Personnalisé' est sélectionnéFormat de date personnalisé (strftime) — actif "
"uniquement quand « Personnalisé » est sélectionné ci-dessus"

#. settings-schema.json->date-format-custom->tooltip
msgid ""
"strftime codes: %A=full weekday  %a=short weekday  %d=day  %B=full month  "
"%b=short month  %Y=4-digit year  %y=2-digit year  %m=month number  %j=day of "
"year  %H=hour(24h)  %I=hour(12h)  %M=minute  %p=AM/PM.  Example: %Y. %B %d., "
"%A"
msgstr "Codes strftime : %A=jour de la semaine complet  %a=jour de la semaine court  %d=jour  %B=mois complet  %b=mois court  %Y=année sur 4 chiffres  %y=année sur 2 chiffres  %m=numéro du mois  %j=jour de l'année  %H=heure(24h)  %I=heure(12h)  %M=minute  %p=AM/PM.  Exemple : %Y. %B %d., %A"

