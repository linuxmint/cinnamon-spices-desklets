#. settings-schema.json->date-format-custom->description
msgid ""
"Custom date format (strftime) — only active when 'Custom' is selected above"
msgstr ""
"Formato de fecha personalizado (strftime) — solo activo cuando se selecciona "
"'Personalizado' arriba"

#. settings-schema.json->date-format-custom->tooltip
msgid ""
"strftime codes: %A=full weekday  %a=short weekday  %d=day  %B=full month  "
"%b=short month  %Y=4-digit year  %y=2-digit year  %m=month number  %j=day of "
"year  %H=hour(24h)  %I=hour(12h)  %M=minute  %p=AM/PM.  Example: %Y. %B %d., "
"%A"
msgstr ""

