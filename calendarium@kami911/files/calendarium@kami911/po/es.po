msgstr "Longitud de la ciudad 3"

#. ── settings-schema.json — tooltips ─────────────────────────────────────
#: settings-schema.json
msgid ""
"Select a predefined date format, or choose Custom to enter your own strftime "
"string below."
msgstr ""
"Selecciona un formato de fecha predefinido, o elige Personalizado para "
"introducir tu propio código strftime abajo."

#: settings-schema.json
msgid "Controls the display size of moon phase and zodiac symbols."
msgstr "Controla el tamaño de los símbolos de fase lunar y zodíaco."

#: settings-schema.json
msgid "Scale all text in the desklet up or down."
msgstr "Ampliar o reducir todo el texto del desklet."

#: settings-schema.json
msgid ""
"How long to keep Wikipedia data in the local cache before fetching fresh "
"data. Lower values fetch more often; higher values reduce network usage."
msgstr ""
"Cuánto tiempo conservar los datos de Wikipedia en la caché local antes de "
"obtener datos nuevos. Valores menores actualizan más a menudo; valores "
"mayores reducen el uso de red."

#: settings-schema.json
msgid "Choose what to show for the western zodiac sign."
msgstr "Elige qué mostrar para el signo del zodíaco occidental."

#: settings-schema.json
msgid "Choose what to show for the Chinese zodiac year (animal and element)."
msgstr "Elige qué mostrar para el año del zodíaco chino (animal y elemento)."

#: settings-schema.json
msgid "Label for an additional city. Leave empty to hide."
msgstr "Etiqueta para una ciudad adicional. Dejar vacío para ocultar."

