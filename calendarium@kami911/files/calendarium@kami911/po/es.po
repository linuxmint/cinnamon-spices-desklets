msgid "Hide desklet decorations (border and header label)"
msgstr "Ocultar decoraciones del desklet (borde y encabezado)"

#: settings-schema.json
msgid "Use manual location (default: Budapest, Hungary)"
msgstr "Usar ubicación manual (predeterminado: Budapest, Hungría)"

#: settings-schema.json
msgid "Latitude (positive = North)"
msgstr "Latitud (positivo = Norte)"

#: settings-schema.json
msgid "Longitude (positive = East)"
msgstr "Longitud (positivo = Este)"

#: settings-schema.json
msgid "City 1 name (leave empty to disable)"
msgstr "Nombre de la ciudad 1 (dejar vacío para desactivar)"

#: settings-schema.json
msgid "City 1 latitude"
msgstr "Latitud de la ciudad 1"

#: settings-schema.json
msgid "City 1 longitude"
msgstr "Longitud de la ciudad 1"

#: settings-schema.json
msgid "City 2 name (leave empty to disable)"
msgstr "Nombre de la ciudad 2 (dejar vacío para desactivar)"

#: settings-schema.json
msgid "City 2 latitude"
msgstr "Latitud de la ciudad 2"

#: settings-schema.json
msgid "City 2 longitude"
msgstr "Longitud de la ciudad 2"

#: settings-schema.json
msgid "City 3 name (leave empty to disable)"
msgstr "Nombre de la ciudad 3 (dejar vacío para desactivar)"

#: settings-schema.json
