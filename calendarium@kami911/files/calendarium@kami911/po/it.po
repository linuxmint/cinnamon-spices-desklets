#. ── settings-schema.json — tooltips ─────────────────────────────────────
#: settings-schema.json
msgid ""
"Select a predefined date format, or choose Custom to enter your own strftime "
"string below."
msgstr ""
"Seleziona un formato data predefinito, o scegli Personalizzato per inserire "
"la tua stringa strftime."

#: settings-schema.json
msgid "Controls the display size of moon phase and zodiac symbols."
msgstr ""
"Controlla la dimensione di visualizzazione dei simboli di fase lunare e "
"zodiaco."

#: settings-schema.json
msgid "Scale all text in the desklet up or down."
msgstr "Ingrandire o ridurre tutto il testo nel desklet."

#: settings-schema.json
msgid ""
"How long to keep Wikipedia data in the local cache before fetching fresh "
"data. Lower values fetch more often; higher values reduce network usage."
msgstr ""
"Per quanto tempo conservare i dati Wikipedia nella cache locale prima di "
"recuperare dati aggiornati. Valori bassi aggiornano più spesso; valori alti "
"riducono il traffico di rete."

#: settings-schema.json
msgid "Choose what to show for the western zodiac sign."
msgstr "Scegli cosa mostrare per il segno zodiacale occidentale."

#: settings-schema.json
msgid "Choose what to show for the Chinese zodiac year (animal and element)."
msgstr ""
"Scegli cosa mostrare per l'anno dello zodiaco cinese (animale ed elemento)."

#: settings-schema.json
msgid "Label for an additional city. Leave empty to hide."
msgstr "Etichetta per una città aggiuntiva. Lascia vuoto per nascondere."

