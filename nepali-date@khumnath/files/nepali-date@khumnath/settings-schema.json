{
    "use-nepali-numerals": {
        "type": "checkbox",
        "default": true,
        "description": "Use Nepali Numerals (०, १, २...)"
    },
    "show-title": {
        "type": "checkbox",
        "default": false,
        "description": "Show 'Today's Date' Title"
    },
    "language": {
        "type": "combobox",
        "default": "nepali",
        "description": "Widget Language",
        "options": {
            "Nepali (नेपाली)": "nepali",
            "English (English)": "english"
        }
    },
    "view-mode": {
        "type": "combobox",
        "default": "full",
        "description": "Default View Mode",
        "options": {
            "Daily View": "daily",
            "Calendar View": "calendar",
            "Full View": "full"
        }
    },
    "layout-style": {
        "type": "combobox",
        "default": "left",
        "description": "Full View Layout",
        "options": {
            "Daily on Top": "top",
            "Daily on Left": "left",
            "Daily on Right": "right"
        }
    },
    "show-time": {
        "type": "checkbox",
        "default": true,
        "description": "Show Time"
    },
    "time-zone": {
        "type": "combobox",
        "default": "nepal",
        "description": "Time Zone Indicator",
        "options": {
            "System Local (स्थानीय)": "local",
            "Nepal Time (नेपाल)": "nepal"
        }
    },
    "show-weekday": {
        "type": "checkbox",
        "default": true,
        "description": "Show Weekday Name"
    },
    "show-gregorian": {
        "type": "checkbox",
        "default": true,
        "description": "Show Gregorian Date"
    },
    "text-color": {
        "type": "colorchooser",
        "default": "rgb(153,193,241)",
        "description": "General Text Color"
    },
    "title-color": {
        "type": "colorchooser",
        "default": "rgb(220,138,221)",
        "description": "Title Color"
    },
    "date-color": {
        "type": "colorchooser",
        "default": "rgba(255,255,255,1)",
        "description": "Daily Date Color"
    },
    "month-color": {
        "type": "colorchooser",
        "default": "rgb(51,209,122)",
        "description": "Month/Year Color"
    },
    "weekday-color": {
        "type": "colorchooser",
        "default": "rgba(255,255,255,0.6)",
        "description": "Weekday Header Color"
    },
    "today-bg-color": {
        "type": "colorchooser",
        "default": "rgb(38,162,105)",
        "description": "Today Highlight Background"
    },
    "today-text-color": {
        "type": "colorchooser",
        "default": "rgb(249,240,107)",
        "description": "Today Highlight Text"
    },
    "time-color": {
        "type": "colorchooser",
        "default": "rgb(98,160,234)",
        "description": "Time Color"
    },
    "bg-color": {
        "type": "colorchooser",
        "default": "rgb(0,0,0)",
        "description": "Background Color"
    },
    "font-size": {
        "type": "spinbutton",
        "default": 12,
        "units": "pt",
        "step": 1,
        "min": 8,
        "max": 72,
        "description": "Base Font Size"
    },
    "widget-scale": {
        "type": "scale",
        "default": 0.7,
        "min": 0.5,
        "max": 2.5,
        "step": 0.1,
        "description": "Widget Scale Factor"
    },
    "bg-opacity": {
        "type": "spinbutton",
        "default": 40,
        "units": "%",
        "step": 5,
        "min": 0,
        "max": 100,
        "description": "Background Opacity"
    }
}
